#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="/etc/pihole-cputemp.conf"
OUT_FILE="/var/www/html/admin/custom/cputemp.json"

WARN_C="60"
CRIT_C="70"
TEMP_FILE="auto"

if [[ -r "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
fi

find_auto_temp_file() {
  local z
  local type
  local best_file=""
  local best_score=0
  local score

  for z in /sys/class/thermal/thermal_zone*; do
    [[ -r "$z/type" && -r "$z/temp" ]] || continue

    type="$(cat "$z/type" 2>/dev/null || true)"
    score=0

    case "$type" in
      cpu-thermal|cpu_thermal|cpu|CPU|x86_pkg_temp|soc-thermal|soc_thermal)
        score=100
        ;;
      *cpu*|*CPU*|*coretemp*|*k10temp*|*soc*|*SoC*|*SOC*)
        score=90
        ;;
      *thermal*)
        score=50
        ;;
      *)
        score=10
        ;;
    esac

    if (( score > best_score )); then
      best_score="$score"
      best_file="$z/temp"
    fi
  done

  if [[ -n "$best_file" ]]; then
    printf '%s\n' "$best_file"
    return 0
  fi

  return 1
}

get_temp_type() {
  local temp_path="$1"
  local zone_dir

  zone_dir="$(dirname "$temp_path")"

  if [[ -r "$zone_dir/type" ]]; then
    cat "$zone_dir/type"
  else
    echo "unknown"
  fi
}

write_error_json() {
  local message="$1"

  mkdir -p "$(dirname "$OUT_FILE")"

  cat > "$OUT_FILE" <<EOF_JSON
{
  "error": "$message",
  "status": "unavailable",
  "icon_class": "text-gray",
  "updated": "$(date --iso-8601=seconds)"
}
EOF_JSON
}

if [[ "$TEMP_FILE" == "auto" ]]; then
  if ! TEMP_FILE="$(find_auto_temp_file)"; then
    write_error_json "temperature source unavailable"
    exit 0
  fi
fi

if [[ ! -r "$TEMP_FILE" ]]; then
  write_error_json "temperature source unavailable"
  exit 0
fi

RAW_TEMP="$(cat "$TEMP_FILE")"

if ! [[ "$RAW_TEMP" =~ ^-?[0-9]+$ ]]; then
  write_error_json "temperature source returned invalid data"
  exit 0
fi

TEMP_C="$(awk -v t="$RAW_TEMP" 'BEGIN { printf "%.1f", t / 1000 }')"
TEMP_F="$(awk -v c="$TEMP_C" 'BEGIN { printf "%.1f", (c * 9 / 5) + 32 }')"
SOURCE_TYPE="$(get_temp_type "$TEMP_FILE")"

STATUS="green"
ICON_CLASS="text-green-light"

if awk -v c="$TEMP_C" -v crit="$CRIT_C" 'BEGIN { exit !(c >= crit) }'; then
  STATUS="red"
  ICON_CLASS="text-red"
elif awk -v c="$TEMP_C" -v warn="$WARN_C" 'BEGIN { exit !(c >= warn) }'; then
  STATUS="yellow"
  ICON_CLASS="text-yellow"
fi

mkdir -p "$(dirname "$OUT_FILE")"

cat > "$OUT_FILE" <<EOF_JSON
{
  "celsius": "$TEMP_C",
  "fahrenheit": "$TEMP_F",
  "status": "$STATUS",
  "icon_class": "$ICON_CLASS",
  "source": "$TEMP_FILE",
  "source_type": "$SOURCE_TYPE",
  "warn_c": "$WARN_C",
  "crit_c": "$CRIT_C",
  "updated": "$(date --iso-8601=seconds)"
}
EOF_JSON
